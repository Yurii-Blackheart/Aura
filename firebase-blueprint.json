{
  "entities": {
    "ChangelogEvent": {
      "title": "ChangelogEvent",
      "description": "An event indicating an update, achievement, or publication in the prismhub ecosystem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "module": { "type": "string" },
        "type": { "type": "string" },
        "targetId": { "type": "string" }
      },
      "required": ["id", "title", "description", "timestamp", "module", "type"]
    },
    "User": {
      "title": "User",
      "description": "User profile with their status and custom events",
      "type": "object",
      "properties": {
        "statusText": { "type": "string" },
        "changelogEvents": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ChangelogEvent"
          }
        },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["admin", "editor", "user"] }
      },
      "required": ["email", "displayName", "updatedAt", "role"]
    },
    "BookLoreEntity": {
      "title": "BookLoreEntity",
      "description": "Lore entity representing a character, location, event, faction, creature, magic, glossary, artifact, codex, or chapter in a book",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "book_id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "summary": { "type": "string" },
        "body": { "type": "string" },
        "image": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "links": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string", "enum": ["draft", "published", "hidden"] }
      },
      "required": ["id", "book_id", "title", "type", "summary", "body", "tags", "links", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Isolated user profile document"
    },
    "book_lore/{loreId}": {
      "schema": "BookLoreEntity",
      "description": "Lore entities associated with books, structured dynamically"
    }
  }
}
